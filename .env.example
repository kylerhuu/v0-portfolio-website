NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-20
# Optional: how often Next re-fetches Sanity (default 60). Lower for faster updates; 0 = always dynamic.
SANITY_FETCH_REVALIDATE_SECONDS=60
# Optional: set to false to bypass Sanity API CDN in production (fresher, more API load).
NEXT_PUBLIC_SANITY_USE_CDN=
